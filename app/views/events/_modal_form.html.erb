<%= turbo_frame_tag "modal", data: { turbo_cache: "false" } do %>
  <div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md overflow-hidden transform transition-all max-h-[90vh] flex flex-col">
      <%# ヘッダー %>
      <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
        <h2 class="text-xl font-bold text-gray-800"><%= title %></h2>
        <%= link_to events_path(start_date: @event.start_time), data: { turbo_frame: "_top" }, class: "text-gray-400 hover:text-gray-600" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        <% end %>
      </div>
      <%# フォーム本体 %>
      <%= form_with(model: @event, data: { turbo_frame: "_top" }, class: "p-6 space-y-4 overflow-y-auto flex-1 min-h-0") do |f| %>
        <% if @event.errors.any? %>
          <div class="relative p-4 bg-white border-2 border-pink-100 rounded-xl shadow-sm">
            <div class="flex items-center space-x-2 text-pink-600">
              <%= @event.errors.count %>箇所ほど、お直しが必要です<span class="text-lg font-mono block">₍ᐢ‥ᐢ₎</span>
            </div>
          </div>
        <% end %>
        <div class="space-y-6" data-controller="time-sync"> <%# 各入力項目の間にゆとりを持たせる %>
          <%# タイトル %>
          <div>
            <div class="flex items-center justify-left mb-2 px-1">
              <%= f.label :title, "タイトル", class: "text-sm font-bold text-gray-600" %>
              <% if @event.errors[:title].any? %>
                <%# 属性名を省いたメッセージを表示 %>
                <span class="text-sm ml-1 pt-0.5 font-medium text-pink-500">
                  <%= @event.errors[:title].first %>
                </span>
              <% end %>
            </div>
            <%= f.text_field :title, placeholder: "例：外乗、十勝など", 
        class: "w-full px-4 py-3 border-gray-200 rounded-xl shadow-sm focus:ring-4 focus:ring-blue-500/10 focus:border-blue-400 transition-all placeholder:text-gray-300" %>
          </div>
          <%# 開始日時 %>
          <div>
            <div class="flex items-center justify-left mb-2 px-1">
              <%= f.label :start_time, "開始日時", class: "text-sm font-bold text-gray-600" %>
              <% if @event.errors[:start_time].any? %>
                <span class="text-sm ml-1 pt-0.5 font-medium text-pink-500">
                  <%= @event.errors[:start_time].first %>
                </span>
              <% end %>
            </div>
            <%= f.datetime_field :start_time, 
      data: { 
        time_sync_target: "start",
        action: "change->time-sync#sync"
      },
      class: "w-full px-4 py-3 border-gray-200 rounded-xl shadow-sm focus:ring-4 focus:ring-blue-500/10 focus:border-blue-400 transition-all color-scheme-light" %>
          </div>
          <%# 終了日時 %>
          <div>
            <div class="flex items-center justify-left mb-2 px-1">
              <%= f.label :end_time, "終了日時", class: "text-sm font-bold text-gray-600" %>
              <% if @event.errors[:end_time].any? %>
                <span class="text-sm ml-1 pt-0.5 font-medium text-pink-500">
                  <%= @event.errors[:end_time].first %>
                </span>
              <% end %>
            </div>
            <%= f.datetime_field :end_time, 
      data: { time_sync_target: "end" },
      class: "w-full px-4 py-3 border-gray-200 rounded-xl shadow-sm focus:ring-4 focus:ring-blue-500/10 focus:border-blue-400 transition-all color-scheme-light" %>
          </div>
          <%# メモ %>
          <div>
            <%= f.label :content, "メモ", class: "block text-sm font-bold text-gray-600 mb-2 ml-1" %>
            <%= f.text_area :content, rows: 4, placeholder: "どんな予定ですか？",
        class: "w-full px-4 py-3 border-gray-200 rounded-xl shadow-sm focus:ring-4 focus:ring-blue-500/10 focus:border-blue-400 transition-all resize-none" %>
          </div>
        </div>
        <div class="flex items-center justify-between pt-4 border-t border-gray-100">
          <% if show_delete %>
            <%= link_to event_path(@event), 
                data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？", turbo_frame: "_top" }, 
                class: "p-2.5 text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors",
                title: "削除" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
              </svg>
            <% end %>
          <% else %>
            <div><%# 削除がない時も justify-between を維持するための空要素 %></div>
          <% end %>
          <div class="flex items-center gap-2">
            <%= link_to events_path(start_date: @event.start_time), 
                data: { turbo_frame: "_top" }, 
                class: "p-2.5 text-gray-500 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors",
                title: "キャンセル" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
              </svg>
            <% end %>
            <%= f.button type: :submit, 
                class: "inline-flex items-center gap-2 px-6 py-2.5 md:text-lg text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 shadow-sm transition-all active:scale-95" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span>保存</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>