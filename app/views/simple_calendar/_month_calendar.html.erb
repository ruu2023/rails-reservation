<%# 1. コンテナ：h-dvhで画面高さを固定、overflow-hiddenで全体スクロールを禁止 %>
<div class="h-dvh flex flex-col bg-white overflow-hidden">
  <%# 2. ヘッダー：高さ固定 %>
  <div class="flex-none flex items-center justify-start p-4 border-b">
    <div class="flex flex-col">
      <h2 class="text-3xl font-black text-gray-800 leading-none">
        <%= t('date.month_names')[start_date.month] %> <span class="text-xl font-light text-gray-400"><%= start_date.year %></span>
      </h2>
    </div>
    <div class="flex items-center space-x-2 ml-20">
      <%= link_to calendar.url_for_previous_view, class: "flex items-center px-4 py-2 bg-white border border-gray-200 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-all duration-200 shadow-sm" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        前
      <% end %>
      <%= link_to calendar.url_for_next_view, class: "flex items-center px-4 py-2 bg-white border border-gray-200 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-all duration-200 shadow-sm" do %>
        次
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      <% end %>
    </div>
  </div>
  <%# 3. 本体エリア：ここにも min-h-0 が必須 %>
  <div class="flex-1 flex flex-col min-h-0 border-l border-b border-gray-200">
    <%# 曜日ヘッダー部分 %>
    <div class="grid grid-cols-7 bg-gray-50 border-t border-b-2 border-gray-200 flex-none">
      <% date_range.slice(0, 7).each do |day| %>
        <div class="py-2 text-[10px] md:text-lg font-bold text-center uppercase border-r border-gray-200 
                <%= 'text-red-500' if day.sunday? %> 
                <%= 'text-blue-500' if day.saturday? %> 
                <%= 'text-gray-500' unless day.saturday? || day.sunday? %>">
          <%= t('date.abbr_day_names')[day.wday] %>
        </div>
      <% end %>
    </div>
    <%# 4. グリッド本体：min-h-0 と minmax(0, 1fr) で、中身に負けず等分を維持 %>
    <% row_count = date_range.size / 7 %>
    <div class="grid grid-cols-7 grow min-h-0" 
         style="grid-template-rows: repeat(<%= row_count %>, minmax(0, 1fr));">
      <% date_range.each do |day| %>
        <%# 各マス：min-h-0 を指定 %>
        <div class="border-t border-r border-gray-200 relative flex flex-col min-h-0 bg-white">
          <%# スクロールエリア：ここだけが回る %>
          <div class="flex-1 overflow-y-auto custom-scrollbar min-h-0">
            <div class="flex justify-between py-0.5 sticky top-0 z-10">
              <%# 祝日名：白縁取りで背後の予定と重なっても読めるようにする %>
              <span class="text-[9px] md:text-sm text-red-500 p-1 font-bold truncate max-w-[65%]"
        style="text-shadow: 1px 1px 0 #fff, -1px -1px 0 #fff, 1px -1px 0 #fff, -1px 1px 0 #fff, 0 0 4px #fff;">
                <%= holiday_name(day) %>
              </span>
              <span class="w-6 h-6 flex items-center justify-center rounded-full border text-gray-600 border-gray-100 text-[10px] md:text-lg font-medium <%= date_class(day) %>">
                <%= day.day %>
              </span>
            </div>
            <%# ここで index.html.erb のブロックを呼び出す %>
            <% instance_exec(day, calendar.sorted_events_for(day), &passed_block) %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>