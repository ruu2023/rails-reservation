<%# 1. コンテナ：h-dvhで画面高さを固定、overflow-hiddenで全体スクロールを禁止 %>
<div class="h-dvh flex flex-col bg-white overflow-hidden">
  <%# 2. ヘッダー：高さ固定 %>
  <div class="flex-none flex items-center justify-start p-4 border-b">
    <h2 class="text-xl font-bold text-gray-800">
      <%= t('date.month_names')[start_date.month] %> <%= start_date.year %>
    </h2>
    <div class="space-x-2 ml-20 flex">
      <%= link_to "前", calendar.url_for_previous_view, class: "px-3 py-1 bg-gray-100 rounded text-sm" %>
      <%= link_to "次", calendar.url_for_next_view, class: "px-3 py-1 bg-gray-100 rounded text-sm" %>
    </div>
  </div>
  <%# 3. 本体エリア：ここにも min-h-0 が必須 %>
  <div class="flex-1 flex flex-col min-h-0 border-l border-b border-gray-200">
    <%# 曜日ヘッダー部分 %>
    <div class="grid grid-cols-7 bg-gray-50 border-t border-b-2 border-gray-200 flex-none">
      <% date_range.slice(0, 7).each do |day| %>
        <div class="py-2 text-[10px] font-bold text-center uppercase border-r border-gray-200 
                <%= 'text-red-500' if day.sunday? %> 
                <%= 'text-blue-500' if day.saturday? %> 
                <%= 'text-gray-500' unless day.saturday? || day.sunday? %>">
          <%= t('date.abbr_day_names')[day.wday] %>
        </div>
      <% end %>
    </div>
    <%# 4. グリッド本体：min-h-0 と minmax(0, 1fr) で、中身に負けず等分を維持 %>
    <% row_count = date_range.size / 7 %>
    <div class="grid grid-cols-7 grow min-h-0" 
         style="grid-template-rows: repeat(<%= row_count %>, minmax(0, 1fr));">
      <% date_range.each do |day| %>
        <%# 各マス：min-h-0 を指定 %>
        <div class="border-t border-r border-gray-200 relative flex flex-col min-h-0 bg-white">
          <%# スクロールエリア：ここだけが回る %>
          <div class="flex-1 overflow-y-auto custom-scrollbar min-h-0">
            <div class="flex justify-between py-0.5 sticky top-0 z-10">
              <%# 祝日名：白縁取りで背後の予定と重なっても読めるようにする %>
              <span class="text-[9px] text-red-500 p-1 font-bold truncate max-w-[65%]"
        style="text-shadow: 1px 1px 0 #fff, -1px -1px 0 #fff, 1px -1px 0 #fff, -1px 1px 0 #fff, 0 0 4px #fff;">
                <%= holiday_name(day) %>
              </span>
              <span class="w-6 h-6 flex items-center justify-center rounded-full border text-gray-600 border-gray-100 text-[10px] font-medium <%= date_class(day) %>">
                <%= day.day %>
              </span>
            </div>
            <%# ここで index.html.erb のブロックを呼び出す %>
            <% instance_exec(day, calendar.sorted_events_for(day), &passed_block) %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>